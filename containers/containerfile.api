FROM python:3.12-slim

WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1

COPY api/pyproject.toml /app/api/pyproject.toml
RUN pip install --no-cache-dir uvicorn fastapi pydantic pydantic-settings httpx

COPY api/thaleos_api /app/thaleos_api

EXPOSE 8080
CMD ["uvicorn", "thaleos_api.main:app", "--host", "0.0.0.0", "--port", "8080"]